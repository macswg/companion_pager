# .env.example
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Analog Way LivePremier — Primary unit (AQ21)
# Used by: Companion Sync, AQ Setup, MV Setup, AQ Clone (export source)
AQ_PRIMARY_HOST=

# Analog Way LivePremier — Backup unit (AQ22)
# Used by: AQ Clone (import target)
AQ_BACKUP_HOST=

# LivePremier REST API port
# Development/testing: 3003
# On-site: typically 80 — confirm from device
AQ_PORT=3003
